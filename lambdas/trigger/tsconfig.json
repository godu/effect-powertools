{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "effect": ["./node_modules/effect"],
      "effect/*": ["./node_modules/effect/*"],
      "@aws-lambda-powertools/*": ["./node_modules/@aws-lambda-powertools/*"],
      "aws-xray-sdk-core": ["./node_modules/aws-xray-sdk-core"],
      "@aws-sdk/*": ["./node_modules/@aws-sdk/*"]
    }
  },
  "include": ["routes", "utils", "nitro.config.ts", "../shared/effect-powertools"]
}
